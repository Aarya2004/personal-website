{
  "name": "personal-website",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "ci": "bun run check && bun run lint",
    "prepare": "husky",
    "chat": "bun run chat/index.ts"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "biome check --write --no-errors-on-unmatched"
    ],
    "*.astro": [
      "astro check"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@astrojs/tailwind": "^5.1.0",
    "@opentui/core": "^0.1.88",
    "@tailwindcss/typography": "^0.5.15",
    "astro": "4.16.18",
    "node-html-parser": "^7.1.0",
    "ollama": "^0.6.3",
    "tailwindcss": "^3.4.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/sitemap": "3.2.1",
    "@biomejs/biome": "^2.4.11",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript": "^6.0.2"
  }
}

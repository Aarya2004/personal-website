---
// AsciiBackground.astro
// Ambient editorial ASCII field rendered to a single fixed-position canvas.
// Decorative only — aria-hidden, pointer-events: none, z-index: -1.
---

<canvas id="ascii-bg" aria-hidden="true"></canvas>
<div id="ascii-vignette" aria-hidden="true"></div>

<style>
  #ascii-bg {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    z-index: -1;
    pointer-events: none;
    display: block;
  }
  #ascii-vignette {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background: radial-gradient(
      ellipse 720px 680px at 50% 45%,
      var(--theme-bg, var(--ascii-bg-color, #ffffff)) 0%,
      var(--theme-bg, var(--ascii-bg-color, #ffffff)) 40%,
      transparent 95%
    );
  }
  :global(html.dark) #ascii-vignette {
    --ascii-bg-color: #0a0a0a; /* neutral-950 */
  }
  :global(html:not(.dark)) #ascii-vignette {
    --ascii-bg-color: #ffffff;
  }
</style>

<script>
  // --- Tunable constants ------------------------------------------------
  const GLYPHS = "····..::,,'`--—+/\\|()[]{}<>aeiorstn";
  const FONT_SIZE = 12;
  const FONT_FAMILY = "'JetBrains Mono', ui-monospace, monospace";
  const BASE_OPACITY_LIGHT = 0.08;
  const BASE_OPACITY_DARK = 0.06;
  const MUTATION_RATE = 0.015;
  const TICK_MS = 50;
  const RIPPLE_RADIUS_CELLS = 6;
  const RIPPLE_DECAY_PER_TICK = 255 / (600 / TICK_MS); // full decay in ~600ms
  const CLICK_RIPPLE_SPEED = 1.5;           // cells per tick
  const CLICK_RIPPLE_THICKNESS = 2.5;       // cell-width of excited annulus at each tick
  const CLICK_RIPPLE_INITIAL_LEVEL = 255;   // peak excitement at ring front
  const CLICK_RIPPLE_MAX_RADIUS_CELLS = 200; // hard cap for ripple lifetime
  const EXCITED_PEAK_OPACITY_BONUS = 0.42;
  const SCROLL_BOOST_MAX = 1.0;
  const SCROLL_BOOST_DECAY = 0.06; // per tick; ~400ms to fully decay
  const SCROLL_VELOCITY_SCALE = 0.01; // px/frame → boost
  const SCROLL_OPACITY_BONUS = 0.04;
  const SCROLL_MUTATION_MULTIPLIER = 4;

  // --- Hidden words constants -------------------------------------------
  const WORDS = [
    'medport', 'lighthouse', 'kotml', 'murmur',
    'toronto', 'dubai', 'uoft', 'distributed',
    'build', 'ship', 'iterate', 'ml',
    'curious',
    '$_', '</>', '0|1',
  ];
  const WORD_REVEAL_THRESHOLD = 80;
  const WORD_REVEAL_HOLD_MS = 1000;
  const WORD_REVEAL_FADE_MS = 1500;
  const WORD_REVEAL_OPACITY = 0.9;
  const WORD_REVEAL_SHADOW = 0;
  const WORD_EXCLUSION_W = 600;
  const WORD_EXCLUSION_H = 500;

  // Multi-line ASCII art pieces. Each piece is an array of equal-width strings.
  // Placed randomly alongside WORDS; reveal mechanic identical.
  const MULTI_ART: string[][] = [
    [
      '*  ',
      '|\\ ',
      '| *',
      '*  ',
    ],
  ];

  // --- State ------------------------------------------------------------
  let canvas: HTMLCanvasElement | null = null;
  let ctx: CanvasRenderingContext2D | null = null;
  let cellW = 0;
  let cellH = 0;
  let cols = 0;
  let rows = 0;
  let glyphs: Uint8Array = new Uint8Array(0);
  let dpr = 1;
  let rafHandle = 0;
  let lastTickTime = 0;
  let reduceMotion = false;
  let paused = false;
  let excitement: Uint8Array = new Uint8Array(0);
  let cursorX = -1;
  let cursorY = -1;
  let cursorDirty = false;
  let hasHover = false;
  interface ClickRipple {
    cx: number;           // center col
    cy: number;           // center row
    radius: number;       // current radius in cells (float, grows each tick)
  }
  let clickRipples: ClickRipple[] = [];
  let scrollBoost = 0;
  let lastScrollY = 0;
  let scrollVelocity = 0;
  let accentR = 192;
  let accentG = 58;
  let accentB = 46;
  let asciiBaseR = 0;
  let asciiBaseG = 0;
  let asciiBaseB = 0;
  let asciiBaseSet = false;
  let rippleGlowMult = 1.0;

  // --- Hidden words state -----------------------------------------------
  interface PlacedWord {
    text: string;
    row: number;
    col: number;
    state: 'ambient' | 'revealing' | 'fading';
    stateStartMs: number;
  }
  let placedWords: PlacedWord[] = [];
  // wordCellMap: index-in-glyphs-array -> index into placedWords (or -1 if none)
  let wordCellMap: Int16Array = new Int16Array(0);
  // Parallel to glyphs[]: if a cell belongs to a word, its actual literal char.
  // Empty string means "use GLYPHS[glyphs[idx]]".
  let wordChars: string[] = [];

  interface PlacedArt {
    lines: string[]; // reference to a MULTI_ART entry
    row: number;     // top-left row
    col: number;     // top-left col
    state: 'ambient' | 'revealing' | 'fading';
    stateStartMs: number;
  }
  let placedArt: PlacedArt[] = [];

  function isDark(): boolean {
    return document.documentElement.classList.contains('dark');
  }

  function baseOpacity(): number {
    return isDark() ? BASE_OPACITY_DARK : BASE_OPACITY_LIGHT;
  }

  function measureCell(): { w: number; h: number } {
    if (!ctx) return { w: 0, h: 0 };
    ctx.font = `${FONT_SIZE}px ${FONT_FAMILY}`;
    const metrics = ctx.measureText('M');
    const w = metrics.width;
    const h = FONT_SIZE * 1.2;
    return { w, h };
  }

  function placeWords(): void {
    placedWords = [];
    wordCellMap = new Int16Array(cols * rows);
    wordCellMap.fill(-1);

    const cxCell = Math.floor((window.innerWidth / 2) / cellW);
    const cyCell = Math.floor((window.innerHeight * 0.45) / cellH);
    const exclRxCells = Math.ceil((WORD_EXCLUSION_W / 2) / cellW);
    const exclRyCells = Math.ceil((WORD_EXCLUSION_H / 2) / cellH);

    for (const text of WORDS) {
      const len = text.length;
      let placed = false;
      for (let attempt = 0; attempt < 30; attempt++) {
        const r = Math.floor(Math.random() * rows);
        const c = Math.floor(Math.random() * (cols - len));
        if (c < 0) continue;

        // Exclusion zone check (ellipse around viewport center).
        const midC = c + len / 2;
        const dx = (midC - cxCell) / exclRxCells;
        const dy = (r - cyCell) / exclRyCells;
        if (dx * dx + dy * dy <= 1) continue;

        // Check overlap with existing placed words (including 2-cell buffer).
        let clear = true;
        for (let k = 0; k < len; k++) {
          for (let dr = -2; dr <= 2 && clear; dr++) {
            for (let dc = -2; dc <= 2 && clear; dc++) {
              const rr = r + dr;
              const cc = c + k + dc;
              if (rr < 0 || rr >= rows || cc < 0 || cc >= cols) continue;
              if (wordCellMap[rr * cols + cc] !== -1) clear = false;
            }
          }
          if (!clear) break;
        }
        if (!clear) continue;

        // Commit placement.
        const wordIdx = placedWords.length;
        placedWords.push({
          text, row: r, col: c,
          state: 'ambient', stateStartMs: 0,
        });
        for (let k = 0; k < len; k++) {
          const idx = r * cols + (c + k);
          wordCellMap[idx] = wordIdx;
          wordChars[idx] = text[k];
        }
        placed = true;
        break;
      }
      // If !placed: silently skip. Acceptable on small viewports.
      void placed;
    }
  }

  function placeArt(): void {
    placedArt = [];
    const cxCell = Math.floor((window.innerWidth / 2) / cellW);
    const cyCell = Math.floor((window.innerHeight * 0.45) / cellH);
    const exclRxCells = Math.ceil((WORD_EXCLUSION_W / 2) / cellW);
    const exclRyCells = Math.ceil((WORD_EXCLUSION_H / 2) / cellH);

    for (const lines of MULTI_ART) {
      const h = lines.length;
      const w = lines[0].length;
      let placed = false;

      for (let attempt = 0; attempt < 30; attempt++) {
        const r = Math.floor(Math.random() * (rows - h));
        const c = Math.floor(Math.random() * (cols - w));
        if (r < 0 || c < 0) continue;

        // Exclusion zone (use the art's center).
        const midR = r + h / 2;
        const midC = c + w / 2;
        const dx = (midC - cxCell) / exclRxCells;
        const dy = (midR - cyCell) / exclRyCells;
        if (dx * dx + dy * dy <= 1) continue;

        // Collision check against existing words and prior art.
        let clear = true;
        for (let dr = 0; dr < h && clear; dr++) {
          for (let dc = 0; dc < w && clear; dc++) {
            // Check a 2-cell buffer around every non-space cell of the art.
            if (lines[dr][dc] === ' ') continue;
            for (let br = -2; br <= 2 && clear; br++) {
              for (let bc = -2; bc <= 2 && clear; bc++) {
                const rr = r + dr + br;
                const cc = c + dc + bc;
                if (rr < 0 || rr >= rows || cc < 0 || cc >= cols) continue;
                if (wordCellMap[rr * cols + cc] !== -1) clear = false;
              }
            }
          }
        }
        if (!clear) continue;

        // Commit. Use a NEGATIVE encoding in wordCellMap to distinguish art
        // cells from word cells: art index + 1, negated, so -1 is "empty".
        // But since -1 already means empty, use -(artIdx + 2) for art cells.
        const artIdx = placedArt.length;
        placedArt.push({
          lines, row: r, col: c,
          state: 'ambient', stateStartMs: 0,
        });
        for (let dr = 0; dr < h; dr++) {
          for (let dc = 0; dc < w; dc++) {
            const ch = lines[dr][dc];
            if (ch === ' ') continue;
            const idx = (r + dr) * cols + (c + dc);
            wordCellMap[idx] = -(artIdx + 2);
            wordChars[idx] = ch;
          }
        }
        placed = true;
        break;
      }
      void placed;
    }
  }

  function repositionWord(wordIdx: number): void {
    const word = placedWords[wordIdx];
    if (!word) return;

    const len = word.text.length;
    const cxCell = Math.floor((window.innerWidth / 2) / cellW);
    const cyCell = Math.floor((window.innerHeight * 0.45) / cellH);
    const exclRxCells = Math.ceil((WORD_EXCLUSION_W / 2) / cellW);
    const exclRyCells = Math.ceil((WORD_EXCLUSION_H / 2) / cellH);

    // Clear old cells first so the overlap check below treats them as free.
    const oldRow = word.row;
    const oldCol = word.col;
    for (let k = 0; k < len; k++) {
      const idx = oldRow * cols + (oldCol + k);
      if (idx >= 0 && idx < wordCellMap.length) {
        wordCellMap[idx] = -1;
        wordChars[idx] = '';
      }
    }

    for (let attempt = 0; attempt < 30; attempt++) {
      const r = Math.floor(Math.random() * rows);
      const c = Math.floor(Math.random() * (cols - len));
      if (c < 0) continue;

      const midC = c + len / 2;
      const dx = (midC - cxCell) / exclRxCells;
      const dy = (r - cyCell) / exclRyCells;
      if (dx * dx + dy * dy <= 1) continue;

      let clear = true;
      for (let k = 0; k < len; k++) {
        for (let dr = -2; dr <= 2 && clear; dr++) {
          for (let dc = -2; dc <= 2 && clear; dc++) {
            const rr = r + dr;
            const cc = c + k + dc;
            if (rr < 0 || rr >= rows || cc < 0 || cc >= cols) continue;
            if (wordCellMap[rr * cols + cc] !== -1) clear = false;
          }
        }
        if (!clear) break;
      }
      if (!clear) continue;

      // Commit new placement.
      word.row = r;
      word.col = c;
      for (let k = 0; k < len; k++) {
        const idx = r * cols + (c + k);
        wordCellMap[idx] = wordIdx;
        wordChars[idx] = word.text[k];
      }
      return;
    }

    // If no placement found in 30 tries, restore to old position so the word still exists.
    word.row = oldRow;
    word.col = oldCol;
    for (let k = 0; k < len; k++) {
      const idx = oldRow * cols + (oldCol + k);
      wordCellMap[idx] = wordIdx;
      wordChars[idx] = word.text[k];
    }
  }

  function repositionArt(artIdx: number): void {
    const art = placedArt[artIdx];
    if (!art) return;
    const lines = art.lines;
    const h = lines.length;
    const w = lines[0].length;
    const cxCell = Math.floor((window.innerWidth / 2) / cellW);
    const cyCell = Math.floor((window.innerHeight * 0.45) / cellH);
    const exclRxCells = Math.ceil((WORD_EXCLUSION_W / 2) / cellW);
    const exclRyCells = Math.ceil((WORD_EXCLUSION_H / 2) / cellH);

    // Clear old cells.
    const oldRow = art.row;
    const oldCol = art.col;
    for (let dr = 0; dr < h; dr++) {
      for (let dc = 0; dc < w; dc++) {
        if (lines[dr][dc] === ' ') continue;
        const idx = (oldRow + dr) * cols + (oldCol + dc);
        if (idx >= 0 && idx < wordCellMap.length) {
          wordCellMap[idx] = -1;
          wordChars[idx] = '';
        }
      }
    }

    for (let attempt = 0; attempt < 30; attempt++) {
      const r = Math.floor(Math.random() * (rows - h));
      const c = Math.floor(Math.random() * (cols - w));
      if (r < 0 || c < 0) continue;
      const midR = r + h / 2;
      const midC = c + w / 2;
      const dx = (midC - cxCell) / exclRxCells;
      const dy = (midR - cyCell) / exclRyCells;
      if (dx * dx + dy * dy <= 1) continue;

      let clear = true;
      for (let dr = 0; dr < h && clear; dr++) {
        for (let dc = 0; dc < w && clear; dc++) {
          if (lines[dr][dc] === ' ') continue;
          for (let br = -2; br <= 2 && clear; br++) {
            for (let bc = -2; bc <= 2 && clear; bc++) {
              const rr = r + dr + br;
              const cc = c + dc + bc;
              if (rr < 0 || rr >= rows || cc < 0 || cc >= cols) continue;
              if (wordCellMap[rr * cols + cc] !== -1) clear = false;
            }
          }
        }
      }
      if (!clear) continue;

      art.row = r;
      art.col = c;
      for (let dr = 0; dr < h; dr++) {
        for (let dc = 0; dc < w; dc++) {
          const ch = lines[dr][dc];
          if (ch === ' ') continue;
          const idx = (r + dr) * cols + (c + dc);
          wordCellMap[idx] = -(artIdx + 2);
          wordChars[idx] = ch;
        }
      }
      return;
    }

    // Fallback: restore old position.
    art.row = oldRow;
    art.col = oldCol;
    for (let dr = 0; dr < h; dr++) {
      for (let dc = 0; dc < w; dc++) {
        if (lines[dr][dc] === ' ') continue;
        const idx = (oldRow + dr) * cols + (oldCol + dc);
        wordCellMap[idx] = -(artIdx + 2);
        wordChars[idx] = lines[dr][dc];
      }
    }
  }

  function resize(): void {
    if (!canvas || !ctx) return;
    dpr = window.devicePixelRatio || 1;
    const cssW = window.innerWidth;
    const cssH = window.innerHeight;
    canvas.width = Math.floor(cssW * dpr);
    canvas.height = Math.floor(cssH * dpr);
    canvas.style.width = `${cssW}px`;
    canvas.style.height = `${cssH}px`;
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

    const cell = measureCell();
    cellW = cell.w;
    cellH = cell.h;
    cols = Math.ceil(cssW / cellW);
    rows = Math.ceil(cssH / cellH);
    glyphs = new Uint8Array(cols * rows);
    for (let i = 0; i < glyphs.length; i++) {
      glyphs[i] = Math.floor(Math.random() * GLYPHS.length);
    }
    excitement = new Uint8Array(cols * rows);
    wordChars = new Array(cols * rows);
    for (let i = 0; i < wordChars.length; i++) wordChars[i] = '';
    placeWords();
    placeArt();
    paintAll();
  }

  function paintAll(): void {
    if (!ctx || !canvas) return;
    // Paint to an offscreen canvas first, then blit in one draw call so the
    // main canvas never shows a partially-painted frame during theme flips.
    const cssW = canvas.width / dpr;
    const cssH = canvas.height / dpr;
    const off = document.createElement('canvas');
    off.width = canvas.width;
    off.height = canvas.height;
    const octx = off.getContext('2d');
    if (!octx) return;
    octx.setTransform(dpr, 0, 0, dpr, 0, 0);
    octx.font = `${FONT_SIZE}px ${FONT_FAMILY}`;
    octx.textBaseline = 'top';
    const op = baseOpacity();
    for (let r = 0; r < rows; r++) {
      for (let c = 0; c < cols; c++) {
        const idx = r * cols + c;
        const style = cellStyle(idx, op);
        octx.fillStyle = style.fill;
        if (style.shadow > 0) {
          octx.shadowColor = style.fill;
          octx.shadowBlur = style.shadow;
        } else {
          octx.shadowBlur = 0;
        }
        octx.fillText(GLYPHS[glyphs[idx]], c * cellW, r * cellH);
      }
    }
    // Single blit to main canvas — no intermediate frame.
    ctx.clearRect(0, 0, cssW, cssH);
    ctx.drawImage(off, 0, 0, cssW, cssH);
    // Restore ctx font/baseline state so subsequent paintCell calls (which
    // assume these are set) continue to work as before.
    ctx.font = `${FONT_SIZE}px ${FONT_FAMILY}`;
    ctx.textBaseline = 'top';
  }

  function readAccent(): void {
    const v = getComputedStyle(document.documentElement).getPropertyValue('--accent-rgb').trim();
    if (!v) return;
    const parts = v.split(/\s+/).map((n) => parseInt(n, 10));
    if (parts.length === 3 && parts.every((n) => !isNaN(n))) {
      [accentR, accentG, accentB] = parts;
    }
  }

  function readAsciiBase(): void {
    const style = getComputedStyle(document.documentElement);
    const v = style.getPropertyValue('--ascii-base-rgb').trim();
    if (v) {
      const parts = v.split(/\s+/).map((n) => parseInt(n, 10));
      if (parts.length === 3 && parts.every((n) => !isNaN(n))) {
        [asciiBaseR, asciiBaseG, asciiBaseB] = parts;
        asciiBaseSet = true;
      } else {
        asciiBaseSet = false;
      }
    } else {
      asciiBaseSet = false;
    }
    const mult = parseFloat(style.getPropertyValue('--ripple-glow-mult'));
    rippleGlowMult = isNaN(mult) || mult <= 0 ? 1.0 : mult;
  }

  function cellStyle(index: number, baseOpacity: number): { fill: string; shadow: number } {
    const e = excitement[index] / 255;
    const s = scrollBoost;
    const opacity = baseOpacity + e * EXCITED_PEAK_OPACITY_BONUS;
    const blend = Math.min(0.9, e * 1.0 + s * 0.4);

    // Base color: theme-provided when in theme mode, otherwise fall back to
    // the neutral dark/light pair driven by the `dark` class.
    let baseR: number, baseG: number, baseB: number;
    if (asciiBaseSet) {
      baseR = asciiBaseR;
      baseG = asciiBaseG;
      baseB = asciiBaseB;
    } else {
      const dark = isDark();
      baseR = baseG = baseB = dark ? 255 : 0;
    }

    // Luminance-based decision for ripple target direction.
    const baseLum = 0.299 * baseR + 0.587 * baseG + 0.114 * baseB;
    const baseIsLight = baseLum > 127;
    let targetR: number, targetG: number, targetB: number;
    if (baseIsLight) {
      targetR = Math.round(accentR + (255 - accentR) * 0.4);
      targetG = Math.round(accentG + (255 - accentG) * 0.4);
      targetB = Math.round(accentB + (255 - accentB) * 0.4);
    } else {
      targetR = Math.round(accentR * 0.75);
      targetG = Math.round(accentG * 0.75);
      targetB = Math.round(accentB * 0.75);
    }

    const r = Math.round(baseR + (targetR - baseR) * blend);
    const g = Math.round(baseG + (targetG - baseG) * blend);
    const b = Math.round(baseB + (targetB - baseB) * blend);

    const shadow = e > 0 ? Math.round(6 * e * rippleGlowMult) : 0;
    return { fill: `rgba(${r},${g},${b},${opacity})`, shadow };
  }

  function paintCell(index: number, baseOpacity: number): void {
    if (!ctx) return;
    const r = Math.floor(index / cols);
    const c = index % cols;
    const x = c * cellW;
    const y = r * cellH;
    ctx.clearRect(x, y, cellW + 1, cellH);
    const style = cellStyle(index, baseOpacity);
    ctx.fillStyle = style.fill;
    if (style.shadow > 0) {
      ctx.shadowColor = style.fill;
      ctx.shadowBlur = style.shadow;
    } else {
      ctx.shadowBlur = 0;
    }
    ctx.fillText(GLYPHS[glyphs[index]], x, y);
  }

  function paintWord(word: PlacedWord, opacity: number, shadow: number, accentBlend: number): void {
    if (!ctx) return;

    // Clear all cells for this word so ambient glyphs underneath don't show through.
    const wordLen = word.text.length;
    const x0 = word.col * cellW;
    const y0 = word.row * cellH;
    const w = wordLen * cellW;
    ctx.clearRect(x0, y0, w + 1, cellH);

    // Resolve base color (matches paintWordCell fallback behavior).
    let baseR: number, baseG: number, baseB: number;
    if (asciiBaseSet) {
      baseR = asciiBaseR;
      baseG = asciiBaseG;
      baseB = asciiBaseB;
    } else {
      const dark = isDark();
      baseR = baseG = baseB = dark ? 255 : 0;
    }

    // Blend accent over base.
    const r2 = Math.round(baseR + (accentR - baseR) * accentBlend);
    const g2 = Math.round(baseG + (accentG - baseG) * accentBlend);
    const b2 = Math.round(baseB + (accentB - baseB) * accentBlend);

    ctx.fillStyle = `rgba(${r2},${g2},${b2},${opacity})`;
    if (shadow > 0) {
      ctx.shadowColor = ctx.fillStyle as string;
      ctx.shadowBlur = shadow;
    } else {
      ctx.shadowBlur = 0;
    }

    // Draw the word as one continuous text — shadow halo forms a single coherent glow.
    ctx.fillText(word.text, x0, y0);
  }

  function paintArt(art: PlacedArt, opacity: number, shadow: number, accentBlend: number): void {
    if (!ctx) return;
    const lines = art.lines;
    const h = lines.length;
    const w = lines[0].length;
    const x0 = art.col * cellW;
    const y0 = art.row * cellH;

    // Clear the art's bounding box.
    ctx.clearRect(x0, y0, w * cellW + 1, h * cellH);

    // Resolve base color (matches paintWord / cellStyle fallback behavior).
    let baseR: number, baseG: number, baseB: number;
    if (asciiBaseSet) {
      baseR = asciiBaseR;
      baseG = asciiBaseG;
      baseB = asciiBaseB;
    } else {
      const dark = isDark();
      baseR = baseG = baseB = dark ? 255 : 0;
    }

    const r2 = Math.round(baseR + (accentR - baseR) * accentBlend);
    const g2 = Math.round(baseG + (accentG - baseG) * accentBlend);
    const b2 = Math.round(baseB + (accentB - baseB) * accentBlend);

    ctx.fillStyle = `rgba(${r2},${g2},${b2},${opacity})`;
    if (shadow > 0) {
      ctx.shadowColor = ctx.fillStyle as string;
      ctx.shadowBlur = shadow;
    } else {
      ctx.shadowBlur = 0;
    }

    // Render each non-space line's characters.
    for (let dr = 0; dr < h; dr++) {
      ctx.fillText(lines[dr], x0, y0 + dr * cellH);
    }
  }

  function advanceClickRipples(): void {
    if (clickRipples.length === 0) return;
    const r2Outer = (r: number) => r * r;
    const toRemove: number[] = [];

    for (let k = 0; k < clickRipples.length; k++) {
      const rp = clickRipples[k];
      const outerR = rp.radius;
      const innerR = Math.max(0, rp.radius - CLICK_RIPPLE_THICKNESS);
      const outerR2 = r2Outer(outerR);
      const innerR2 = r2Outer(innerR);

      // Bounding box for the annulus.
      const minC = Math.max(0, Math.floor(rp.cx - outerR));
      const maxC = Math.min(cols - 1, Math.ceil(rp.cx + outerR));
      const minR = Math.max(0, Math.floor(rp.cy - outerR));
      const maxR = Math.min(rows - 1, Math.ceil(rp.cy + outerR));

      for (let rr = minR; rr <= maxR; rr++) {
        for (let cc = minC; cc <= maxC; cc++) {
          const dc = cc - rp.cx;
          const dr = rr - rp.cy;
          const d2 = dc * dc + dr * dr;
          if (d2 <= outerR2 && d2 >= innerR2) {
            // Fade excitement toward edge of annulus so the ring has a soft front.
            const d = Math.sqrt(d2);
            const falloff = 1 - Math.abs(d - (outerR - CLICK_RIPPLE_THICKNESS / 2)) / (CLICK_RIPPLE_THICKNESS / 2 + 0.01);
            const level = Math.max(0, Math.min(CLICK_RIPPLE_INITIAL_LEVEL, Math.floor(CLICK_RIPPLE_INITIAL_LEVEL * Math.max(0, falloff))));
            const idx = rr * cols + cc;
            if (level > excitement[idx]) excitement[idx] = level;
          }
        }
      }

      rp.radius += CLICK_RIPPLE_SPEED;
      if (rp.radius > CLICK_RIPPLE_MAX_RADIUS_CELLS) toRemove.push(k);
    }

    // Remove expired ripples (iterate backward to keep indices valid).
    for (let i = toRemove.length - 1; i >= 0; i--) {
      clickRipples.splice(toRemove[i], 1);
    }
  }

  function tick(now: number): void {
    if (paused) return;
    if (!ctx) return;
    if (now - lastTickTime >= TICK_MS) {
      lastTickTime = now;
      // Update scroll boost from velocity, then decay velocity sample.
      const target = Math.min(SCROLL_BOOST_MAX, scrollVelocity * SCROLL_VELOCITY_SCALE);
      if (target > scrollBoost) scrollBoost = target;
      scrollBoost = Math.max(0, scrollBoost - SCROLL_BOOST_DECAY);
      scrollVelocity = 0;

      const opacity = baseOpacity() + scrollBoost * SCROLL_OPACITY_BONUS;

      // Apply cursor excitement to cells near the cursor.
      if (cursorDirty && cursorX >= 0 && cursorY >= 0) {
        const cc = Math.floor(cursorX / cellW);
        const cr = Math.floor(cursorY / cellH);
        const r2 = RIPPLE_RADIUS_CELLS * RIPPLE_RADIUS_CELLS;
        for (let dr = -RIPPLE_RADIUS_CELLS; dr <= RIPPLE_RADIUS_CELLS; dr++) {
          for (let dc = -RIPPLE_RADIUS_CELLS; dc <= RIPPLE_RADIUS_CELLS; dc++) {
            const d2 = dr * dr + dc * dc;
            if (d2 > r2) continue;
            const rr = cr + dr;
            const cc2 = cc + dc;
            if (rr < 0 || rr >= rows || cc2 < 0 || cc2 >= cols) continue;
            const falloff = 1 - Math.sqrt(d2) / RIPPLE_RADIUS_CELLS;
            const level = Math.min(255, Math.floor(255 * falloff));
            const idx = rr * cols + cc2;
            if (level > excitement[idx]) excitement[idx] = level;
          }
        }
        cursorDirty = false;
      }

      // Advance click ripples.
      advanceClickRipples();

      // Ambient random mutations (skip word cells).
      const mutations = Math.floor(
        glyphs.length * MUTATION_RATE * (1 + scrollBoost * (SCROLL_MUTATION_MULTIPLIER - 1))
      );
      for (let i = 0; i < mutations; i++) {
        const idx = Math.floor(Math.random() * glyphs.length);
        glyphs[idx] = Math.floor(Math.random() * GLYPHS.length);
        paintCell(idx, opacity);
      }

      // Word reveal state machine.
      if (placedWords.length > 0) {
        const nowMs = now; // rAF timestamp
        for (let w = 0; w < placedWords.length; w++) {
          const word = placedWords[w];
          const wordLen = word.text.length;

          if (word.state === 'ambient') {
            // Check if any cell of the word has excitement above threshold.
            let triggered = false;
            for (let k = 0; k < wordLen; k++) {
              const idx = word.row * cols + (word.col + k);
              if (excitement[idx] >= WORD_REVEAL_THRESHOLD) {
                triggered = true;
                break;
              }
            }
            if (triggered) {
              word.state = 'revealing';
              word.stateStartMs = nowMs;
              paintWord(word, WORD_REVEAL_OPACITY, WORD_REVEAL_SHADOW * rippleGlowMult, 1.0);
            }
          } else if (word.state === 'revealing') {
            if (nowMs - word.stateStartMs >= WORD_REVEAL_HOLD_MS) {
              word.state = 'fading';
              word.stateStartMs = nowMs;
            } else {
              paintWord(word, WORD_REVEAL_OPACITY, WORD_REVEAL_SHADOW * rippleGlowMult, 1.0);
            }
          } else if (word.state === 'fading') {
            const t = (nowMs - word.stateStartMs) / WORD_REVEAL_FADE_MS;
            if (t >= 1) {
              // First paint the OLD cells back to ambient so no residue remains.
              for (let k = 0; k < wordLen; k++) {
                const idx = word.row * cols + (word.col + k);
                paintCell(idx, opacity);
              }
              word.state = 'ambient';
              word.stateStartMs = 0;
              // Pick a new random position for this word.
              repositionWord(w);
            } else {
              const fadeProgress = 1 - t;
              const op = opacity + (WORD_REVEAL_OPACITY - opacity) * fadeProgress;
              const sh = WORD_REVEAL_SHADOW * rippleGlowMult * fadeProgress;
              paintWord(word, op, sh, fadeProgress);
            }
          }
        }
      }

      // Multi-line ASCII art state machine (mirrors the word state machine).
      if (placedArt.length > 0) {
        const nowMs2 = now;
        for (let a = 0; a < placedArt.length; a++) {
          const art = placedArt[a];
          const lines = art.lines;
          const hh = lines.length;
          const ww = lines[0].length;

          if (art.state === 'ambient') {
            // Trigger if ANY non-space cell of the art has excitement above threshold.
            let triggered = false;
            for (let dr = 0; dr < hh && !triggered; dr++) {
              for (let dc = 0; dc < ww && !triggered; dc++) {
                if (lines[dr][dc] === ' ') continue;
                const idx = (art.row + dr) * cols + (art.col + dc);
                if (excitement[idx] >= WORD_REVEAL_THRESHOLD) triggered = true;
              }
            }
            if (triggered) {
              art.state = 'revealing';
              art.stateStartMs = nowMs2;
              paintArt(art, WORD_REVEAL_OPACITY, WORD_REVEAL_SHADOW * rippleGlowMult, 1.0);
            }
          } else if (art.state === 'revealing') {
            if (nowMs2 - art.stateStartMs >= WORD_REVEAL_HOLD_MS) {
              art.state = 'fading';
              art.stateStartMs = nowMs2;
            } else {
              paintArt(art, WORD_REVEAL_OPACITY, WORD_REVEAL_SHADOW * rippleGlowMult, 1.0);
            }
          } else if (art.state === 'fading') {
            const t = (nowMs2 - art.stateStartMs) / WORD_REVEAL_FADE_MS;
            if (t >= 1) {
              // Paint old cells back to ambient.
              for (let dr = 0; dr < hh; dr++) {
                for (let dc = 0; dc < ww; dc++) {
                  if (lines[dr][dc] === ' ') continue;
                  const idx = (art.row + dr) * cols + (art.col + dc);
                  paintCell(idx, opacity);
                }
              }
              art.state = 'ambient';
              art.stateStartMs = 0;
              repositionArt(a);
            } else {
              const fadeProgress = 1 - t;
              const op = opacity + (WORD_REVEAL_OPACITY - opacity) * fadeProgress;
              const sh = WORD_REVEAL_SHADOW * rippleGlowMult * fadeProgress;
              paintArt(art, op, sh, fadeProgress);
            }
          }
        }
      }

      // Excited cells re-roll every tick and decay.
      for (let i = 0; i < excitement.length; i++) {
        if (excitement[i] === 0) continue;
        if (wordCellMap[i] === -1) {
          // Non-word cells: re-roll glyph as before.
          glyphs[i] = Math.floor(Math.random() * GLYPHS.length);
        }
        paintCell(i, opacity);
        const next = excitement[i] - RIPPLE_DECAY_PER_TICK;
        excitement[i] = next > 0 ? next : 0;
        if (excitement[i] === 0) {
          // One final repaint at baseline to shed the excitement glow.
          paintCell(i, opacity);
        }
      }
    }
    rafHandle = requestAnimationFrame(tick);
  }

  function startLoop(): void {
    if (reduceMotion) return;
    if (rafHandle) cancelAnimationFrame(rafHandle);
    lastTickTime = 0;
    rafHandle = requestAnimationFrame(tick);
  }

  function stopLoop(): void {
    if (rafHandle) cancelAnimationFrame(rafHandle);
    rafHandle = 0;
  }

  function init(): void {
    canvas = document.getElementById('ascii-bg') as HTMLCanvasElement | null;
    if (!canvas) return;
    ctx = canvas.getContext('2d');
    if (!ctx) return;
    resize();
    readAccent();
    readAsciiBase();
    stopLoop();
    startLoop();
  }

  // Register module-level listeners exactly once.
  let themeRafPending = 0;
  const themeObserver = new MutationObserver(() => {
    if (themeRafPending) return;
    themeRafPending = requestAnimationFrame(() => {
      themeRafPending = 0;
      readAccent();
      readAsciiBase();
      paintAll();
    });
  });
  themeObserver.observe(document.documentElement, {
    attributes: true,
    attributeFilter: ['class', 'data-theme-active', 'style'],
  });

  document.addEventListener('astro:after-swap', () => {
    init();
  });

  let resizeTimer: number | undefined;
  window.addEventListener('resize', () => {
    if (resizeTimer) window.clearTimeout(resizeTimer);
    resizeTimer = window.setTimeout(resize, 150);
  });

  const motionMQ = window.matchMedia('(prefers-reduced-motion: reduce)');
  reduceMotion = motionMQ.matches;
  motionMQ.addEventListener('change', (e) => {
    reduceMotion = e.matches;
    if (reduceMotion) {
      stopLoop();
    } else if (!paused) {
      startLoop();
    }
  });

  document.addEventListener('visibilitychange', () => {
    paused = document.hidden;
    if (paused) {
      stopLoop();
    } else if (!reduceMotion) {
      paintAll();
      startLoop();
    }
  });

  document.addEventListener('theme-change', () => {
    readAccent();
    readAsciiBase();
    paintAll();
  });

  hasHover = window.matchMedia('(hover: hover)').matches;

  if (hasHover) {
    window.addEventListener(
      'mousemove',
      (e) => {
        if (reduceMotion) return;
        cursorX = e.clientX;
        cursorY = e.clientY;
        cursorDirty = true;
      },
      { passive: true }
    );
  }

  lastScrollY = window.scrollY;
  window.addEventListener(
    'scroll',
    () => {
      if (reduceMotion) return;
      const y = window.scrollY;
      scrollVelocity = Math.abs(y - lastScrollY);
      lastScrollY = y;
    },
    { passive: true }
  );

  function handleClick(clientX: number, clientY: number, target: EventTarget | null): void {
    if (reduceMotion) return;
    if (!canvas) return;
    // Ignore clicks on interactive content.
    if (target instanceof Element) {
      const interactive = target.closest(
        'a, button, input, textarea, select, label, [data-theme-picker], [data-no-ripple]'
      );
      if (interactive) return;
    }
    const cc = clientX / cellW;
    const cy = clientY / cellH;
    clickRipples.push({ cx: cc, cy: cy, radius: 0 });
  }

  window.addEventListener(
    'mousedown',
    (e) => {
      // Only primary button.
      if (e.button !== 0) return;
      handleClick(e.clientX, e.clientY, e.target);
    },
    { passive: true }
  );

  window.addEventListener(
    'touchstart',
    (e) => {
      const t = e.touches[0];
      if (!t) return;
      handleClick(t.clientX, t.clientY, e.target);
    },
    { passive: true }
  );

  init();
</script>

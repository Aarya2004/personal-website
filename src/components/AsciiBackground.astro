---
// AsciiBackground.astro
// Ambient editorial ASCII field rendered to a single fixed-position canvas.
// Decorative only — aria-hidden, pointer-events: none, z-index: -1.
---

<canvas id="ascii-bg" aria-hidden="true"></canvas>
<div id="ascii-vignette" aria-hidden="true"></div>

<style>
  #ascii-bg {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    z-index: -1;
    pointer-events: none;
    display: block;
  }
  #ascii-vignette {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background: radial-gradient(
      ellipse 720px 680px at 50% 45%,
      var(--theme-bg, var(--ascii-bg-color, #ffffff)) 0%,
      var(--theme-bg, var(--ascii-bg-color, #ffffff)) 40%,
      transparent 95%
    );
  }
  :global(html.dark) #ascii-vignette {
    --ascii-bg-color: #0a0a0a; /* neutral-950 */
  }
  :global(html:not(.dark)) #ascii-vignette {
    --ascii-bg-color: #ffffff;
  }
</style>

<script>
  // --- Tunable constants ------------------------------------------------
  const GLYPHS = "····..::,,'`--—+/\\|()[]{}<>aeiorstn";
  const FONT_SIZE = 12;
  const FONT_FAMILY = "'JetBrains Mono', ui-monospace, monospace";
  const BASE_OPACITY_LIGHT = 0.08;
  const BASE_OPACITY_DARK = 0.06;
  const MUTATION_RATE = 0.015;
  const TICK_MS = 50;
  const RIPPLE_RADIUS_CELLS = 6;
  const RIPPLE_DECAY_PER_TICK = 255 / (600 / TICK_MS); // full decay in ~600ms
  const CLICK_RIPPLE_SPEED = 1.5;           // cells per tick
  const CLICK_RIPPLE_THICKNESS = 2.5;       // cell-width of excited annulus at each tick
  const CLICK_RIPPLE_INITIAL_LEVEL = 255;   // peak excitement at ring front
  const CLICK_RIPPLE_MAX_RADIUS_CELLS = 200; // hard cap for ripple lifetime
  const EXCITED_PEAK_OPACITY_BONUS = 0.42;
  const SCROLL_BOOST_MAX = 1.0;
  const SCROLL_BOOST_DECAY = 0.06; // per tick; ~400ms to fully decay
  const SCROLL_VELOCITY_SCALE = 0.01; // px/frame → boost
  const SCROLL_OPACITY_BONUS = 0.04;
  const SCROLL_MUTATION_MULTIPLIER = 4;

  // --- State ------------------------------------------------------------
  let canvas: HTMLCanvasElement | null = null;
  let ctx: CanvasRenderingContext2D | null = null;
  let cellW = 0;
  let cellH = 0;
  let cols = 0;
  let rows = 0;
  let glyphs: Uint8Array = new Uint8Array(0);
  let dpr = 1;
  let rafHandle = 0;
  let lastTickTime = 0;
  let reduceMotion = false;
  let paused = false;
  let excitement: Uint8Array = new Uint8Array(0);
  let cursorX = -1;
  let cursorY = -1;
  let cursorDirty = false;
  let hasHover = false;
  interface ClickRipple {
    cx: number;           // center col
    cy: number;           // center row
    radius: number;       // current radius in cells (float, grows each tick)
  }
  let clickRipples: ClickRipple[] = [];
  let scrollBoost = 0;
  let lastScrollY = 0;
  let scrollVelocity = 0;
  let accentR = 192;
  let accentG = 58;
  let accentB = 46;
  let asciiBaseR = 0;
  let asciiBaseG = 0;
  let asciiBaseB = 0;
  let asciiBaseSet = false;
  let rippleGlowMult = 1.0;

  function isDark(): boolean {
    return document.documentElement.classList.contains('dark');
  }

  function baseOpacity(): number {
    return isDark() ? BASE_OPACITY_DARK : BASE_OPACITY_LIGHT;
  }

  function measureCell(): { w: number; h: number } {
    if (!ctx) return { w: 0, h: 0 };
    ctx.font = `${FONT_SIZE}px ${FONT_FAMILY}`;
    const metrics = ctx.measureText('M');
    const w = metrics.width;
    const h = FONT_SIZE * 1.2;
    return { w, h };
  }

  function resize(): void {
    if (!canvas || !ctx) return;
    dpr = window.devicePixelRatio || 1;
    const cssW = window.innerWidth;
    const cssH = window.innerHeight;
    canvas.width = Math.floor(cssW * dpr);
    canvas.height = Math.floor(cssH * dpr);
    canvas.style.width = `${cssW}px`;
    canvas.style.height = `${cssH}px`;
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

    const cell = measureCell();
    cellW = cell.w;
    cellH = cell.h;
    cols = Math.ceil(cssW / cellW);
    rows = Math.ceil(cssH / cellH);
    glyphs = new Uint8Array(cols * rows);
    excitement = new Uint8Array(cols * rows);
    for (let i = 0; i < glyphs.length; i++) {
      glyphs[i] = Math.floor(Math.random() * GLYPHS.length);
    }
    paintAll();
  }

  function paintAll(): void {
    if (!ctx || !canvas) return;
    ctx.clearRect(0, 0, canvas.width / dpr, canvas.height / dpr);
    ctx.font = `${FONT_SIZE}px ${FONT_FAMILY}`;
    ctx.textBaseline = 'top';
    ctx.shadowBlur = 0;
    const op = baseOpacity();
    for (let r = 0; r < rows; r++) {
      for (let c = 0; c < cols; c++) {
        const idx = r * cols + c;
        const style = cellStyle(idx, op);
        ctx.fillStyle = style.fill;
        if (style.shadow > 0) {
          ctx.shadowColor = style.fill;
          ctx.shadowBlur = style.shadow;
        } else {
          ctx.shadowBlur = 0;
        }
        ctx.fillText(GLYPHS[glyphs[idx]], c * cellW, r * cellH);
      }
    }
  }

  function readAccent(): void {
    const v = getComputedStyle(document.documentElement).getPropertyValue('--accent-rgb').trim();
    if (!v) return;
    const parts = v.split(/\s+/).map((n) => parseInt(n, 10));
    if (parts.length === 3 && parts.every((n) => !isNaN(n))) {
      [accentR, accentG, accentB] = parts;
    }
  }

  function readAsciiBase(): void {
    const style = getComputedStyle(document.documentElement);
    const v = style.getPropertyValue('--ascii-base-rgb').trim();
    if (v) {
      const parts = v.split(/\s+/).map((n) => parseInt(n, 10));
      if (parts.length === 3 && parts.every((n) => !isNaN(n))) {
        [asciiBaseR, asciiBaseG, asciiBaseB] = parts;
        asciiBaseSet = true;
      } else {
        asciiBaseSet = false;
      }
    } else {
      asciiBaseSet = false;
    }
    const mult = parseFloat(style.getPropertyValue('--ripple-glow-mult'));
    rippleGlowMult = isNaN(mult) || mult <= 0 ? 1.0 : mult;
  }

  function cellStyle(index: number, baseOpacity: number): { fill: string; shadow: number } {
    const e = excitement[index] / 255;
    const s = scrollBoost;
    const opacity = baseOpacity + e * EXCITED_PEAK_OPACITY_BONUS;
    const blend = Math.min(0.9, e * 1.0 + s * 0.4);

    // Base color: theme-provided when in theme mode, otherwise fall back to
    // the neutral dark/light pair driven by the `dark` class.
    let baseR: number, baseG: number, baseB: number;
    if (asciiBaseSet) {
      baseR = asciiBaseR;
      baseG = asciiBaseG;
      baseB = asciiBaseB;
    } else {
      const dark = isDark();
      baseR = baseG = baseB = dark ? 255 : 0;
    }

    // Luminance-based decision for ripple target direction.
    const baseLum = 0.299 * baseR + 0.587 * baseG + 0.114 * baseB;
    const baseIsLight = baseLum > 127;
    let targetR: number, targetG: number, targetB: number;
    if (baseIsLight) {
      targetR = Math.round(accentR + (255 - accentR) * 0.4);
      targetG = Math.round(accentG + (255 - accentG) * 0.4);
      targetB = Math.round(accentB + (255 - accentB) * 0.4);
    } else {
      targetR = Math.round(accentR * 0.75);
      targetG = Math.round(accentG * 0.75);
      targetB = Math.round(accentB * 0.75);
    }

    const r = Math.round(baseR + (targetR - baseR) * blend);
    const g = Math.round(baseG + (targetG - baseG) * blend);
    const b = Math.round(baseB + (targetB - baseB) * blend);

    const shadow = e > 0 ? Math.round(6 * e * rippleGlowMult) : 0;
    return { fill: `rgba(${r},${g},${b},${opacity})`, shadow };
  }

  function paintCell(index: number, baseOpacity: number): void {
    if (!ctx) return;
    const r = Math.floor(index / cols);
    const c = index % cols;
    const x = c * cellW;
    const y = r * cellH;
    ctx.clearRect(x, y, cellW + 1, cellH);
    const style = cellStyle(index, baseOpacity);
    ctx.fillStyle = style.fill;
    if (style.shadow > 0) {
      ctx.shadowColor = style.fill;
      ctx.shadowBlur = style.shadow;
    } else {
      ctx.shadowBlur = 0;
    }
    ctx.fillText(GLYPHS[glyphs[index]], x, y);
  }

  function advanceClickRipples(): void {
    if (clickRipples.length === 0) return;
    const r2Outer = (r: number) => r * r;
    const toRemove: number[] = [];

    for (let k = 0; k < clickRipples.length; k++) {
      const rp = clickRipples[k];
      const outerR = rp.radius;
      const innerR = Math.max(0, rp.radius - CLICK_RIPPLE_THICKNESS);
      const outerR2 = r2Outer(outerR);
      const innerR2 = r2Outer(innerR);

      // Bounding box for the annulus.
      const minC = Math.max(0, Math.floor(rp.cx - outerR));
      const maxC = Math.min(cols - 1, Math.ceil(rp.cx + outerR));
      const minR = Math.max(0, Math.floor(rp.cy - outerR));
      const maxR = Math.min(rows - 1, Math.ceil(rp.cy + outerR));

      for (let rr = minR; rr <= maxR; rr++) {
        for (let cc = minC; cc <= maxC; cc++) {
          const dc = cc - rp.cx;
          const dr = rr - rp.cy;
          const d2 = dc * dc + dr * dr;
          if (d2 <= outerR2 && d2 >= innerR2) {
            // Fade excitement toward edge of annulus so the ring has a soft front.
            const d = Math.sqrt(d2);
            const falloff = 1 - Math.abs(d - (outerR - CLICK_RIPPLE_THICKNESS / 2)) / (CLICK_RIPPLE_THICKNESS / 2 + 0.01);
            const level = Math.max(0, Math.min(CLICK_RIPPLE_INITIAL_LEVEL, Math.floor(CLICK_RIPPLE_INITIAL_LEVEL * Math.max(0, falloff))));
            const idx = rr * cols + cc;
            if (level > excitement[idx]) excitement[idx] = level;
          }
        }
      }

      rp.radius += CLICK_RIPPLE_SPEED;
      if (rp.radius > CLICK_RIPPLE_MAX_RADIUS_CELLS) toRemove.push(k);
    }

    // Remove expired ripples (iterate backward to keep indices valid).
    for (let i = toRemove.length - 1; i >= 0; i--) {
      clickRipples.splice(toRemove[i], 1);
    }
  }

  function tick(now: number): void {
    if (paused) return;
    if (!ctx) return;
    if (now - lastTickTime >= TICK_MS) {
      lastTickTime = now;
      // Update scroll boost from velocity, then decay velocity sample.
      const target = Math.min(SCROLL_BOOST_MAX, scrollVelocity * SCROLL_VELOCITY_SCALE);
      if (target > scrollBoost) scrollBoost = target;
      scrollBoost = Math.max(0, scrollBoost - SCROLL_BOOST_DECAY);
      scrollVelocity = 0;

      const opacity = baseOpacity() + scrollBoost * SCROLL_OPACITY_BONUS;

      // Apply cursor excitement to cells near the cursor.
      if (cursorDirty && cursorX >= 0 && cursorY >= 0) {
        const cc = Math.floor(cursorX / cellW);
        const cr = Math.floor(cursorY / cellH);
        const r2 = RIPPLE_RADIUS_CELLS * RIPPLE_RADIUS_CELLS;
        for (let dr = -RIPPLE_RADIUS_CELLS; dr <= RIPPLE_RADIUS_CELLS; dr++) {
          for (let dc = -RIPPLE_RADIUS_CELLS; dc <= RIPPLE_RADIUS_CELLS; dc++) {
            const d2 = dr * dr + dc * dc;
            if (d2 > r2) continue;
            const rr = cr + dr;
            const cc2 = cc + dc;
            if (rr < 0 || rr >= rows || cc2 < 0 || cc2 >= cols) continue;
            const falloff = 1 - Math.sqrt(d2) / RIPPLE_RADIUS_CELLS;
            const level = Math.min(255, Math.floor(255 * falloff));
            const idx = rr * cols + cc2;
            if (level > excitement[idx]) excitement[idx] = level;
          }
        }
        cursorDirty = false;
      }

      // Advance click ripples.
      advanceClickRipples();

      // Ambient random mutations.
      const mutations = Math.floor(
        glyphs.length * MUTATION_RATE * (1 + scrollBoost * (SCROLL_MUTATION_MULTIPLIER - 1))
      );
      for (let i = 0; i < mutations; i++) {
        const idx = Math.floor(Math.random() * glyphs.length);
        glyphs[idx] = Math.floor(Math.random() * GLYPHS.length);
        paintCell(idx, opacity);
      }

      // Excited cells re-roll every tick and decay.
      for (let i = 0; i < excitement.length; i++) {
        if (excitement[i] === 0) continue;
        glyphs[i] = Math.floor(Math.random() * GLYPHS.length);
        paintCell(i, opacity);
        const next = excitement[i] - RIPPLE_DECAY_PER_TICK;
        excitement[i] = next > 0 ? next : 0;
        if (excitement[i] === 0) {
          // One final repaint at baseline to shed the excitement glow.
          paintCell(i, opacity);
        }
      }
    }
    rafHandle = requestAnimationFrame(tick);
  }

  function startLoop(): void {
    if (reduceMotion) return;
    if (rafHandle) cancelAnimationFrame(rafHandle);
    lastTickTime = 0;
    rafHandle = requestAnimationFrame(tick);
  }

  function stopLoop(): void {
    if (rafHandle) cancelAnimationFrame(rafHandle);
    rafHandle = 0;
  }

  function init(): void {
    canvas = document.getElementById('ascii-bg') as HTMLCanvasElement | null;
    if (!canvas) return;
    ctx = canvas.getContext('2d');
    if (!ctx) return;
    resize();
    readAccent();
    readAsciiBase();
    stopLoop();
    startLoop();
  }

  // Register module-level listeners exactly once.
  let themeRafPending = 0;
  const themeObserver = new MutationObserver(() => {
    if (themeRafPending) return;
    themeRafPending = requestAnimationFrame(() => {
      themeRafPending = 0;
      readAccent();
      readAsciiBase();
      paintAll();
    });
  });
  themeObserver.observe(document.documentElement, {
    attributes: true,
    attributeFilter: ['class', 'data-theme-active', 'style'],
  });

  document.addEventListener('astro:after-swap', () => {
    init();
  });

  let resizeTimer: number | undefined;
  window.addEventListener('resize', () => {
    if (resizeTimer) window.clearTimeout(resizeTimer);
    resizeTimer = window.setTimeout(resize, 150);
  });

  const motionMQ = window.matchMedia('(prefers-reduced-motion: reduce)');
  reduceMotion = motionMQ.matches;
  motionMQ.addEventListener('change', (e) => {
    reduceMotion = e.matches;
    if (reduceMotion) {
      stopLoop();
    } else if (!paused) {
      startLoop();
    }
  });

  document.addEventListener('visibilitychange', () => {
    paused = document.hidden;
    if (paused) {
      stopLoop();
    } else if (!reduceMotion) {
      paintAll();
      startLoop();
    }
  });

  document.addEventListener('theme-change', () => {
    readAccent();
    readAsciiBase();
    paintAll();
  });

  hasHover = window.matchMedia('(hover: hover)').matches;

  if (hasHover) {
    window.addEventListener(
      'mousemove',
      (e) => {
        if (reduceMotion) return;
        cursorX = e.clientX;
        cursorY = e.clientY;
        cursorDirty = true;
      },
      { passive: true }
    );
  }

  lastScrollY = window.scrollY;
  window.addEventListener(
    'scroll',
    () => {
      if (reduceMotion) return;
      const y = window.scrollY;
      scrollVelocity = Math.abs(y - lastScrollY);
      lastScrollY = y;
    },
    { passive: true }
  );

  function handleClick(clientX: number, clientY: number, target: EventTarget | null): void {
    if (reduceMotion) return;
    if (!canvas) return;
    // Ignore clicks on interactive content.
    if (target instanceof Element) {
      const interactive = target.closest(
        'a, button, input, textarea, select, label, [data-theme-picker], [data-no-ripple]'
      );
      if (interactive) return;
    }
    const cc = clientX / cellW;
    const cy = clientY / cellH;
    clickRipples.push({ cx: cc, cy: cy, radius: 0 });
  }

  window.addEventListener(
    'mousedown',
    (e) => {
      // Only primary button.
      if (e.button !== 0) return;
      handleClick(e.clientX, e.clientY, e.target);
    },
    { passive: true }
  );

  window.addEventListener(
    'touchstart',
    (e) => {
      const t = e.touches[0];
      if (!t) return;
      handleClick(t.clientX, t.clientY, e.target);
    },
    { passive: true }
  );

  init();
</script>

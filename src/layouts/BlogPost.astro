---
import Layout from './Layout.astro';
import type { CollectionEntry } from 'astro:content';
import { personal } from '../data/personal';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, tags, author, image } = post.data;

const canonicalUrl = new URL(`/blog/${post.slug}/`, Astro.site).href;
const articleImage = new URL(image?.url ?? '/og-image.jpg', Astro.site).href;
const authorName = author ?? personal.name;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  author: {
    '@type': 'Person',
    name: authorName,
    url: Astro.site?.href,
  },
  publisher: {
    '@type': 'Person',
    name: personal.name,
    url: Astro.site?.href,
  },
  image: articleImage,
  url: canonicalUrl,
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonicalUrl,
  },
  keywords: tags,
  inLanguage: 'en-US',
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: Astro.site?.href },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: new URL('/blog/', Astro.site).href },
    { '@type': 'ListItem', position: 3, name: title, item: canonicalUrl },
  ],
};
---

<Layout
  title={title}
  description={description}
  activeNav="blog"
  ogType="article"
  ogImage={image?.url ?? '/og-image.jpg'}
  ogImageAlt={image?.alt ?? title}
  pubDate={pubDate}
  updatedDate={updatedDate}
  tags={tags}
  extraSchemas={[articleSchema, breadcrumbSchema]}
>
  <article>
    <header class="mb-8">
      <time class="text-sm text-neutral-500 dark:text-neutral-400 theme-text-muted" datetime={pubDate.toISOString()}>
        {pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
      <span class="text-sm text-neutral-500 dark:text-neutral-400 theme-text-muted"> · {authorName}</span>
      <h1 class="mt-2 text-3xl font-bold tracking-tight sm:text-4xl">
        {title}
      </h1>
      {tags.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-2">
          {tags.map((tag) => (
            <span class="rounded-full bg-[color:var(--accent-muted)] px-3 py-1 text-xs font-medium text-[color:var(--accent)]">
              {tag}
            </span>
          ))}
        </div>
      )}
    </header>
    <div class="prose dark:prose-invert prose-neutral max-w-none prose-headings:font-serif prose-headings:italic prose-headings:font-normal">
      <slot />
    </div>
  </article>
</Layout>

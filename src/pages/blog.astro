---
import Layout from '../layouts/Layout.astro';
import BlogPostCard from '../components/BlogPostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

function readingTime(body: string): string {
  const words = body.trim().split(/\s+/).length;
  return `${Math.max(1, Math.round(words / 200))} min read`;
}
---

<Layout title="Blog" description="Thoughts and writings" activeNav="blog">
  <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">Blog</h1>
  <p class="mt-2 text-neutral-600 dark:text-neutral-400">Thoughts, learnings, and things I find interesting.</p>

  {posts.length === 0 ? (
    <div class="mt-12 rounded-xl border border-dashed border-neutral-300 dark:border-neutral-700 theme-card-border p-10 text-center">
      <p class="text-sm uppercase tracking-widest text-neutral-500 dark:text-neutral-400 theme-text-muted">Coming soon</p>
      <p class="mt-3 text-neutral-700 dark:text-neutral-300">First posts are being written. Check back shortly.</p>
    </div>
  ) : (
    <div class="mt-10 flex flex-col gap-4">
      {posts.map((post) => (
        <BlogPostCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          tags={post.data.tags}
          slug={post.slug}
          readingTime={readingTime(post.body)}
        />
      ))}
    </div>
  )}
</Layout>

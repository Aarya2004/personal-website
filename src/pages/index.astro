---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import BlogPostCard from '../components/BlogPostCard.astro';
import Social from '../components/Social.astro';
import { projects } from '../data/projects';
import { personal } from '../data/personal';
import { getCollection } from 'astro:content';

const featuredProjects = projects.filter((p) => p.featured);

function readingTime(body: string): string {
  const words = body.trim().split(/\s+/).length;
  return `${Math.max(1, Math.round(words / 200))} min read`;
}
const recentPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<Layout title={personal.name} description="Personal website and blog" activeNav="home">

  <!-- Bio -->
  <section class="pb-12">
    <div class="flex flex-col sm:flex-row items-start gap-6">
      <picture>
        <source srcset="/headshot.webp" type="image/webp" />
        <img
          src="/headshot.jpg"
          alt={personal.name}
          width="112"
          height="112"
          class="h-28 w-28 rounded-full object-cover ring-2 ring-neutral-200 dark:ring-neutral-700 shrink-0"
        />
      </picture>
      <div>
        <h1 class="text-4xl font-semibold tracking-tight sm:text-5xl">
          {personal.name}
        </h1>
        <p class="mt-2 text-lg text-neutral-500 dark:text-neutral-400">
          {personal.tagline}
        </p>
        <p class="mt-1 flex items-center gap-1 text-sm text-neutral-500 dark:text-neutral-400">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
          </svg>
          {personal.location}
        </p>
      </div>
    </div>

    <p class="mt-6 text-neutral-600 dark:text-neutral-400 leading-relaxed">
      {personal.bio}
    </p>

    <div class="mt-6 flex flex-wrap items-center gap-4">
      <Social platform="github" username={personal.github} />
      <Social platform="linkedin" username={personal.linkedin} />
      <Social platform="email" username={personal.email} />
      <a
        href={personal.resumePath}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 rounded-lg bg-[color:var(--accent)] px-4 py-2 text-sm font-medium text-[color:var(--accent-contrast,#fff)] hover:brightness-110 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[color:var(--accent)] focus-visible:ring-offset-2 transition-all"
      >
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
        </svg>
        Resume
      </a>
    </div>
  </section>

  <hr class="border-neutral-200 dark:border-neutral-800" />

  <!-- Currently working on -->
  <section data-animate class="py-12">
    <h2 class="text-2xl font-semibold">Current</h2>
    <p class="mt-3 text-neutral-700 dark:text-neutral-300">
      {personal.currentlyWorkingOn}
    </p>
    {personal.currentRoles.length > 1 ? (
      <div class="mt-5 flex flex-col gap-3">
        {personal.currentRoles.map((role) => (
          <div class="flex items-start gap-3">
            <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-sm bg-[color:var(--accent)]" aria-hidden="true"></span>
            <span class="text-neutral-700 dark:text-neutral-300">{role}</span>
          </div>
        ))}
      </div>
    ) : personal.currentRoles.length === 1 ? (
      <p class="mt-4 text-sm text-neutral-500 dark:text-neutral-400 theme-text-muted">
        {personal.currentRoles[0]}
      </p>
    ) : null}
  </section>

  <hr class="border-neutral-200 dark:border-neutral-800" />

  <!-- Past -->
  <section data-animate class="py-12">
    <h2 class="text-2xl font-semibold">Past</h2>
    <div class="mt-5 flex flex-col gap-3">
      {personal.pastRoles.map((role) => (
        <div class="flex items-start gap-3">
          <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-sm bg-[color:var(--accent)] opacity-60" aria-hidden="true"></span>
          <span class="text-neutral-700 dark:text-neutral-300">{role}</span>
        </div>
      ))}
    </div>
  </section>

  <hr class="border-neutral-200 dark:border-neutral-800" />

  <!-- Featured Projects -->
  <section data-animate class="py-12">
    <div class="flex items-center justify-between">
      <h2 class="text-2xl font-semibold">Featured Projects</h2>
      <a href="/projects" class="text-sm text-neutral-500 hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors">
        View all &rarr;
      </a>
    </div>
    <div class="mt-6 grid gap-4 sm:grid-cols-2">
      {featuredProjects.map((project) => (
        <ProjectCard project={project} />
      ))}
    </div>
  </section>

  <hr class="border-neutral-200 dark:border-neutral-800" />

  <!-- Latest Posts -->
  <section data-animate class="py-12">
    <div class="flex items-center justify-between">
      <h2 class="text-2xl font-semibold">Latest Posts</h2>
      <a href="/blog" class="text-sm text-neutral-500 hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors">
        Read more &rarr;
      </a>
    </div>
    {recentPosts.length === 0 ? (
      <div class="mt-6 rounded-xl border border-dashed border-neutral-300 dark:border-neutral-700 theme-card-border p-8 text-center">
        <p class="text-sm uppercase tracking-widest text-neutral-500 dark:text-neutral-400 theme-text-muted">Coming soon</p>
        <p class="mt-3 text-sm text-neutral-700 dark:text-neutral-300">First posts are being written.</p>
      </div>
    ) : (
      <div class="mt-6 flex flex-col gap-4">
        {recentPosts.map((post) => (
          <BlogPostCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            tags={post.data.tags}
            slug={post.slug}
            readingTime={readingTime(post.body)}
          />
        ))}
      </div>
    )}
  </section>
</Layout>
